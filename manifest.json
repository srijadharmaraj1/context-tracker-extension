{
    "manifest_version": 3,
    "name": "Smart Context Dashboard",
    "version": "4.0",
    "permissions": ["storage", "tabs", "notifications"],
    "host_permissions": ["<all_urls>"],
    "action": {
      "default_popup": "popup.html"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ]
  }